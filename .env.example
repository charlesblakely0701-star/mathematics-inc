# Copy to .env.local for local dev (gitignored).
# In production these are set in the Vercel project settings.

# Postgres connection string. Use Neon (https://neon.tech) free tier.
# Example: postgresql://user:password@ep-xyz-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
RESEND_API_KEY=re_...
# After verifying a domain in Resend, set a sender on that domain (required to
# deliver to arbitrary Gmail, etc.):
# RESEND_FROM_EMAIL="Mathematics Inc. <hello@yourdomain.com>"

# Google OAuth (optional). Lets users sign in with any Gmail without Resend domain setup.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (must match the port you actually use):
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3001/api/auth/callback/google  (if port 3000 is busy)
#   https://mathematics-inc.vercel.app/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_URL=http://localhost:3000
# Dev only — if Google sign-in fails with UNABLE_TO_VERIFY_LEAF_SIGNATURE (corporate proxy):
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Auth.js secret. Generate with: `openssl rand -base64 32`
AUTH_SECRET=

# Optional. Auth.js auto-detects this on Vercel; set explicitly only when needed
# (e.g. behind a reverse proxy or for local non-localhost dev).
# AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=123456789-xxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxx