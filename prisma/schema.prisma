// Mathematics, Inc. — User model plus token tables for email verification
// and password reset. Auth.js v5 with the Credentials provider + JWT sessions
// does not require Account/Session/VerificationToken tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  name              String
  title             String?
  department        String?
  bio               String?
  researchInterests String[] @default([])
  websiteUrl        String?
  favoriteTheorem   String?
  // null = unverified (only for accounts created after email verification was
  // introduced). Seeded/admin accounts are pre-verified via db:seed.
  emailVerified     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  @@index([department])
}

// Stores SHA-256 hash of the raw token (never the raw token itself).
// One active token per user; old tokens are replaced on each request.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
